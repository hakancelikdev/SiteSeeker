{
  "manifest_version": 2,
  "name": "Fast History Search",
  "version": "1.0",
  "description": "Tarayıcı geçmişini kullanarak hızlı arama yapmanı sağlar.",
  "permissions": [
    "history",
    "storage"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "fast-history-search@hakancelik.dev",
      "strict_min_version": "57.0"
    }
  }
} 