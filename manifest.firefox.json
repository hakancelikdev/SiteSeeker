{
  "manifest_version": 2,
  "name": "SiteSeeker",
  "version": "1.0",
  "description": "Tarayıcı geçmişini kullanarak hızlı arama yapmanı sağlar.",
  "permissions": [
    "history",
    "storage"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "icons": {
    "128": "icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "siteseeker@hakancelik.dev",
      "strict_min_version": "57.0"
    }
  }
} 