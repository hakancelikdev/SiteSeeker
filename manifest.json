{
  "manifest_version": 3,
  "name": "Fast History Search",
  "version": "1.0",
  "description": "Tarayıcı geçmişini kullanarak hızlı arama yapmanı sağlar.",
  "permissions": [
    "history",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
} 