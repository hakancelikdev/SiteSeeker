{
  "manifest_version": 3,
  "name": "SiteSeeker",
  "version": "1.0",
  "description": "Tarayıcı geçmişini kullanarak hızlı arama yapmanı sağlar.",
  "permissions": [
    "history",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon.png"
  }
} 