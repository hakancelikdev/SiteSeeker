{
  "name": "siteseeker",
  "version": "1.0.0",
  "description": "A native macOS application for searching through browser history and bookmarks",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "DEBUG=true electron .",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "build": "electron-builder build --mac --universal",
    "build:universal": "electron-builder build --mac --universal",
    "build:arm64": "electron-builder build --mac --arm64",
    "build:x64": "electron-builder build --mac --x64",
    "test": "jest"
  },
  "build": {
    "appId": "com.hakancelik.siteseeker",
    "productName": "SiteSeeker",
    "mac": {
      "category": "public.app-category.utilities",
      "target": "zip",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "directories": {
      "buildResources": "build",
      "output": "dist"
    }
  },
  "author": "Hakan Çelik",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/preset-env": "^7.26.9",
    "babel-jest": "^29.7.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "electron-log": "^5.3.3",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.6.2"
  }
}
