{
  "manifest_version": 2,
  "name": "SiteSeeker",
  "version": "1.0.0",
  "description": "Quick access to your browser history with advanced search capabilities",
  "permissions": [
    "history",
    "nativeMessaging"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "siteseeker@hakancelik.dev",
      "strict_min_version": "57.0"
    }
  }
} 